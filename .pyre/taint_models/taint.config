{
  "comment": "Sigil-ML taint configuration for Pysa security analysis",
  "sources": [
    { "name": "UserInput", "comment": "Data from API request bodies" },
    { "name": "SQLResult", "comment": "Data read from SQLite database" },
    { "name": "PluginData", "comment": "Data from sigild plugin HTTP API" }
  ],
  "sinks": [
    { "name": "SQLExecution", "comment": "SQL query execution" },
    { "name": "FileWrite", "comment": "Writing to filesystem" },
    { "name": "ShellExecution", "comment": "Command execution" },
    { "name": "HTTPRequest", "comment": "Outbound HTTP requests" }
  ],
  "features": [
    { "name": "via-sqlite", "comment": "Flows through SQLite" },
    { "name": "via-http", "comment": "Flows through HTTP" }
  ],
  "rules": [
    {
      "name": "SQL Injection",
      "code": 1001,
      "sources": ["UserInput"],
      "sinks": ["SQLExecution"],
      "message_format": "User input flows into SQL execution without parameterization"
    },
    {
      "name": "Command Injection",
      "code": 1002,
      "sources": ["UserInput"],
      "sinks": ["ShellExecution"],
      "message_format": "User input flows into shell command execution"
    },
    {
      "name": "Unsafe Plugin Data to SQL",
      "code": 1003,
      "sources": ["PluginData"],
      "sinks": ["SQLExecution"],
      "message_format": "Plugin data flows into SQL execution without parameterization"
    }
  ]
}
